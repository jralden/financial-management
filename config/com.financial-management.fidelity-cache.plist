<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.financial-management.fidelity-cache</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/johnalden/Documents/Development/Financial/Financial-Management/.venv/bin/python</string>
        <string>-m</string>
        <string>src.fidelity.cache_service</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/johnalden/Documents/Development/Financial/Financial-Management</string>

    <!-- Run every 5 minutes -->
    <key>StartInterval</key>
    <integer>300</integer>

    <!-- Also run at load (immediate first fetch) -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Log output -->
    <key>StandardOutPath</key>
    <string>/Users/johnalden/.cache/financial-management/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/johnalden/.cache/financial-management/launchd-stderr.log</string>

    <!-- Environment variables -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <!-- Keep alive on failure (retry after crash) -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Throttle restarts (wait 60s after failure before retry) -->
    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
